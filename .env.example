# Copia este archivo como .env y completá los valores

# Clave secreta para firmar los JWT (mínimo 32 caracteres en Base64)
JWT_SECRET=

# Duración del token en milisegundos (86400000 = 24 horas)
JWT_EXPIRATION=86400000

# Credenciales del usuario administrador inicial
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
